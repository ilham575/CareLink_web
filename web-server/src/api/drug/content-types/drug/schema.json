{
  "kind": "collectionType",
  "collectionName": "drugs",
  "info": {
    "singularName": "drug",
    "pluralName": "drugs",
    "displayName": "Drug"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name_th": {
      "type": "string"
    },
    "name_en": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "manufacturer": {
      "type": "string",
      "description": "ชื่อยี่ห้า - ชื่อที่บริษัทตั้งขึ้นเพื่อจำหน่ายยา"
    },
    "price": {
      "type": "decimal"
    },
    "suggested_time": {
      "type": "time"
    },
    "take_morning": {
      "type": "boolean",
      "default": false
    },
    "take_lunch": {
      "type": "boolean",
      "default": false
    },
    "take_evening": {
      "type": "boolean",
      "default": false
    },
    "take_bedtime": {
      "type": "boolean",
      "default": false
    },
    "meal_relation": {
      "type": "enumeration",
      "enum": [
        "before",
        "after",
        "with_meal",
        "none"
      ],
      "default": "after"
    },
    "dosage_per_time": {
      "type": "string",
      "default": ""
    },
    "frequency_hours": {
      "type": "integer",
      "default": 0
    },
    "drug_store": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::drug-store.drug-store",
      "inversedBy": "drugs"
    },
    "drug_batches": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::drug-batch.drug-batch",
      "mappedBy": "drug"
    }
  }
}
