# Cloud Run Environment Variables Template

# Database (Cloud SQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=/cloudsql/YOUR_PROJECT:REGION:INSTANCE_NAME
DATABASE_PORT=5432
DATABASE_NAME=carelink
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=YOUR_DATABASE_PASSWORD
DATABASE_SSL=false

# Strapi Secrets (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
APP_KEYS=YOUR_APP_KEYS_HERE
API_TOKEN_SALT=YOUR_API_TOKEN_SALT
ADMIN_JWT_SECRET=YOUR_ADMIN_JWT_SECRET
TRANSFER_TOKEN_SALT=YOUR_TRANSFER_TOKEN_SALT
JWT_SECRET=YOUR_JWT_SECRET

# Server Config
HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# Public URL (will be your Cloud Run URL)
STRAPI_URL=https://your-service-xxxxx.run.app
PUBLIC_URL=https://your-service-xxxxx.run.app
STRAPI_ADMIN_BACKEND_URL=https://your-service-xxxxx.run.app

# Optional: Telegram
TELEGRAM_TOKEN=
TELEGRAM_BOT_NAME=

# Socket Config
SOCKET_ALLOWED_ORIGINS=*
